{
    "name": "corepine/support",
    "description": "Shared support utilities for Corepine packages.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "support",
        "colors",
        "corepine"
    ],
    "authors": [
        {
            "name": "Namu Makwembo",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4|^8.5",
        "laravel/framework": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.24|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.34|^3.0",
        "pestphp/pest-plugin-laravel": "^2.4|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Corepine\\Support\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Corepine\\Support\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "@php vendor/bin/pest"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Corepine\\Support\\SupportServiceProvider"
            ],
            "aliases": {
                "CorepineColor": "Corepine\\Support\\Facades\\CorepineColor"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
